# AI Humanizer Environment Configuration Template
# Copy this file to .env and customize for your environment

# ==================== Ollama Configuration ====================
# Ollama host URL
OLLAMA_HOST=http://localhost:11434

# Ollama model to use
# Options: llama2, llama3.2, mistral, neural-chat, etc.
OLLAMA_MODEL=llama2

# ==================== API Configuration ====================
# API host binding
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Debug mode (True/False)
# Set to False in production
DEBUG=True

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Text Processing Configuration ====================
# Maximum text length (characters)
MAX_TEXT_LENGTH=10000

# Minimum text length (characters)
MIN_TEXT_LENGTH=10

# Request timeout (seconds)
REQUEST_TIMEOUT=60

# ==================== CORS Configuration ====================
# Allowed origins (comma-separated for multiple domains)
# For development: http://localhost:3000,http://localhost:8000
# For production: specify your domain(s) only
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== Model-Specific Settings ====================
# Temperature for LLM responses (0.0-1.0)
# Lower = more deterministic, Higher = more creative
LLM_TEMPERATURE=0.7

# Top P for nucleus sampling (0.0-1.0)
LLM_TOP_P=0.9

# ==================== Deployment ====================
# Environment type: development, staging, production
ENVIRONMENT=development

# Application version (for monitoring)
APP_VERSION=1.0.0