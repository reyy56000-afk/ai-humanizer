# AI Humanizer Environment Configuration Template
# Copy this file to .env and customize for your environment

# ==================== Ollama Configuration ====================
# Ollama host URL
OLLAMA_HOST=http://localhost:11434

# Ollama model to use
# Options: llama2, llama3.2, mistral, neural-chat, etc.
OLLAMA_MODEL=llama2

# ==================== API Configuration ====================
# API host binding
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Debug mode (True/False)
# Set to False in production
DEBUG=True

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Text Processing Configuration ====================
# Maximum text length (characters)
MAX_TEXT_LENGTH=10000

# Minimum text length (characters)
MIN_TEXT_LENGTH=10

# Request timeout (seconds)
REQUEST_TIMEOUT=60

# ==================== Database Configuration (Future) ====================
# DATABASE_URL=sqlite:///./ai_humanizer.db
# SQLALCHEMY_ECHO=False

# ==================== Cache Configuration (Future) ====================
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600

# ==================== Authentication (Future) ====================
# API_KEY_ENABLED=False
# API_SECRET_KEY=your-secret-key-here

# ==================== CORS Configuration ====================
# Allow all origins (development only)
CORS_ORIGINS=*

# ==================== Monitoring & Logging ====================
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ==================== Email Configuration (Future) ====================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@ai-humanizer.com

# ==================== Rate Limiting (Future) ====================
# RATE_LIMIT_ENABLED=False
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD=60

# ==================== Feature Flags ====================
# Enable humanization
FEATURE_HUMANIZE=True

# Enable AI detection
FEATURE_DETECT=True

# Enable text improvement
FEATURE_IMPROVE=True

# Enable summarization
FEATURE_SUMMARIZE=True

# Enable tone adjustment
FEATURE_TONE=True

# Enable batch processing
FEATURE_BATCH=True

# ==================== Performance Tuning ====================
# Worker threads for concurrent processing
WORKER_THREADS=4

# Connection pool size
CONNECTION_POOL_SIZE=10

# ==================== Model-Specific Settings ====================
# Temperature for LLM responses (0.0-1.0)
# Lower = more deterministic, Higher = more creative
LLM_TEMPERATURE=0.7

# Top P for nucleus sampling (0.0-1.0)
LLM_TOP_P=0.9

# Maximum tokens in response
LLM_MAX_TOKENS=2048

# ==================== Deployment ====================
# Environment type: development, staging, production
ENVIRONMENT=development

# Application version (for monitoring)
APP_VERSION=1.0.0

# ==================== Security ====================
# Enable HTTPS only (production)
HTTPS_ONLY=False

# Session timeout (minutes)
SESSION_TIMEOUT=30

# Max login attempts
MAX_LOGIN_ATTEMPTS=5

# ==================== Notification Settings (Future) ====================
# Discord webhook for alerts (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack webhook for alerts (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ==================== Custom Prompts ====================
# Use custom prompt templates
USE_CUSTOM_PROMPTS=False

# Path to custom prompts file
# CUSTOM_PROMPTS_PATH=./custom_prompts.json
